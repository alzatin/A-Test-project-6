    {
      "atomType": "Code",
      "x": 0.7315096251266464,
      "y": 0.4909638554216868,
      "uniqueID": "id-770",
      "ioValues": [
        {
          "name": "sketch2",
          "ioValue": "__GEOMETRY_INPUT__"
        },
        {
          "name": "tool",
          "ioValue": "__GEOMETRY_INPUT__"
        }
      ],
      "codeVersion": 1,
      "code": "\n// Example Code\nconst Inputs = [\n  { inputName: \"tool\", type: \"geometry\", defaultValue: null },\n  { inputName: \"sketch2\", type: \"geometry\", defaultValue: null },\n];\nlet planex = replicad.makePlane(\"XY\").translateZ(10)\nlet baseCircle = replicad.drawEllipse(10, 5).translate([50,0])\nlet sketchCircle = baseCircle.sketchOnPlane(planex)\n\nlet topCircle = replicad.drawEllipse(10, 5)\nlet sketchTopCircle = topCircle.sketchOnPlane(\"ZY\")\n\n//let newPlane = replicad.makePlane()\nlet loftShape = sketchCircle.loftWith(\n  sketchTopCircle, \n   {}, \n   true)\nconsole.log(loftShape)\nlet cutShape = library[tool].geometry[0]\n\nconsole.log(cutShape)\nlet cylObj = {\n  geometry: [replicad.makeSolid([loftShape])],\n  dimension: \"3D\",\n  tags: [\"createdCylinder\"],\n  color: \"#A3CE5B\",\n  plane: null,\n  bom: []\n};\nconsole.log(cylObj)\n\nreturn cylObj\n"
    },
    {
      "atomType": "Code",
      "x": 0.7152988855116514,
      "y": 0.7108433734939759,
      "uniqueID": "id-822",
      "ioValues": [
        {
          "name": "sketch1",
          "ioValue": "__GEOMETRY_INPUT__"
        },
        {
          "name": "sketch2",
          "ioValue": "__GEOMETRY_INPUT__"
        }
      ],
      "codeVersion": 1,
      "code": "\n// Example Code\nconst Inputs = [\n  { inputName: \"sketch1\", type: \"geometry\", defaultValue: null },\n  { inputName: \"sketch2\", type: \"geometry\", defaultValue: null },\n];\n\nlet planex = replicad.makePlane(\"XY\").translateZ(10)\nconst sketchSketch = library[sketch1].geometry[0].sketchOnPlane(\"XY\")\nconsole.log(\"sketch\" ,library[sketch1].geometry[0].sketchOnPlane(\"XY\"))\n\nconsole.log(\"sketch2\" ,library[sketch2].geometry[0])\nconst sketchSketch2 = library[sketch2].geometry[0].sketchOnPlane(planex)\n\nlet baseCircle = replicad.drawEllipse(10, 5).translate([50,0])\nlet sketchCircle = baseCircle.sketchOnPlane(planex)\n\nlet topCircle = replicad.drawEllipse(10, 5)\nlet sketchTopCircle = topCircle.sketchOnPlane(\"ZY\")\n\n//let newPlane = replicad.makePlane()\nlet loftShape = sketchSketch.loftWith(\n  sketchSketch2, \n   {}, \n   false).clone().shell(-1.1,  (face) =>\n    face.inPlane(planex));\nlet cylObj = {\n  geometry: [loftShape],\n  dimension: \"3D\",\n  tags: [\"createdCylinder\"],\n  color: \"#A3CE5B\",\n  plane: null,\n  bom: []\n};\n\nreturn cylObj\n"
    },
